  "schemaVersion": "1.0.0",
  "world": {
    "id": "world_demo_crossroads",
    "name": "雾灯驿站",
    "summary": "两天内，送信人要在雾起前校准路口雾灯，决定旅人能否安全通过。",
    "editorBackground": "雾灯驿站是一个用于测试内容包切换的极简故事包，故事范围限制在一处路口、一名守灯人、一盏雾灯和一次短对话内。时间跨度为两天，每天早晨、正午、夜晚三个时段，玩家行动点有限，核心目标是让雾灯信号保持清晰，使旅人能够识别安全道路。地图、NPC、交互、任务、事件和结局都围绕“路口信号是否可靠”展开；内容不得扩展出大型支线、隐藏势力或复杂调查，只保留雾、灯、驿站职责和路人安全这几个要素。该包主要用于验证内容包 manifest、玩家身份、地图渲染、行动执行、会话触发、事件判断和结局落点能够在客户端中完整串联，因此新增内容应短小、明确、便于回归测试。",
    "maxDays": 2,
    "segments": [
      "morning",
      "noon",
      "night"
    ],
    "actionPointsPerSegment": 2
  },
  "variables": [
    {
      "key": "signal_clarity",
      "name": "雾灯清晰度",
      "description": "雾灯信号是否足以指引路人。",
      "initialValue": 40,
      "min": 0,
      "max": 100
    },
    {
      "key": "traveler_safety",
      "name": "旅人安全",
      "description": "即将经过驿站的旅人安全程度。",
      "initialValue": 50,
      "min": 0,
      "max": 100
    }
  ],
